# Bloquear ejecución de scripts en este directorio.
# Sin esto, un atacante que suba un .php puede ejecutar código.

Options -ExecCGI
AddType application/octet-stream .php .php3 .php4 .php5 .php7 .phtml .phar .pl .py .rb .cgi .sh .asp .aspx .jsp

<FilesMatch "\.(php[0-9]?|phtml|phar|pl|py|rb|cgi|sh|asp|aspx|jsp)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Apache 2.4+ compatible
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php[0-9]?|phtml|phar|pl|py|rb|cgi|sh|asp|aspx|jsp)$">
        Require all denied
    </FilesMatch>
</IfModule>
