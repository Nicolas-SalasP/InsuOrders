<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap/bootstrap.php"
         colors="true"
         stopOnFailure="false">

    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">src/App/Services</directory>
            <directory suffix=".php">src/App/Utils</directory>
        </include>
    </coverage>

    <php>
        <env name="APP_ENV"    value="testing"/>
        <env name="DB_HOST"    value="127.0.0.1"/>
        <env name="DB_NAME"    value="insuban_test"/>
        <env name="DB_USER"    value="root"/>
        <env name="DB_PASS"    value=""/>
        <env name="JWT_SECRET" value="test_secret_key_for_phpunit_only_not_production"/>
    </php>
</phpunit>
