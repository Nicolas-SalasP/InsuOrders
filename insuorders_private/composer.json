{
    "require": {
        "setasign/fpdf": "^1.8",
        "firebase/php-jwt": "^6.11",
        "phpoffice/phpspreadsheet": "^5.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":        "phpunit --testdox",
        "test:unit":   "phpunit --testdox --testsuite=Unit",
        "test:feature":"phpunit --testdox --testsuite=Feature",
        "test:cov":    "phpunit --coverage-html coverage/"
    }
}
